{
  "name": "hermes-webgpu",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Hermes Agent — a tool-calling agent (à la NousResearch/hermes-agent) running 100% in-browser on Soyuz via llama.cpp WebGPU",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:hf": "npm run build && python3 scripts/deploy_hf.py",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@reeselevine/wllama-webgpu": "^1.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "happy-dom": "^15.11.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^2.1.0"
  }
}
