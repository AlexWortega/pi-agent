{
  "name": "piagent-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Pi Agent — Soyuz coding assistant running 100% in-browser via llama.cpp WebGPU",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "deploy:hf": "npm run build && python3 scripts/deploy_hf.py",
    "duel:provision": "node scripts/runpod-duel-provision.mjs",
    "duel:setup": "bash scripts/duel-setup.sh",
    "duel:run": "bash scripts/duel-run.sh"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.78.0",
    "@earendil-works/pi-ai": "^0.78.0",
    "@reeselevine/wllama-webgpu": "^1.0.0",
    "diff": "^8.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright-core": "^1.60.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
